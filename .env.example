# Database
DATABASE_URL=postgresql://username:password@host:5432/elizdehar_db

# Server
PORT=5000
NODE_ENV=development

# Optional production/deployment values
SESSION_SECRET=change-me
JWT_SECRET=change-me-too
DOMAIN=elizdehar.com
PROTOCOL=https

# Optional analytics
GOOGLE_ANALYTICS_ID=
GOOGLE_TAG_MANAGER_ID=
FACEBOOK_PIXEL_ID=

# Optional email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Optional rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional uploads/logging
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
LOG_LEVEL=info
SENTRY_DSN=
