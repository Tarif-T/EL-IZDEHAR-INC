{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/api/seo?type=sitemap"
    },
    {
      "source": "/robots.txt",
      "destination": "/api/seo?type=robots"
    },
    {
      "source": "/opensearch.xml",
      "destination": "/api/seo?type=opensearch"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
